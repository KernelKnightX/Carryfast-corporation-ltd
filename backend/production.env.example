ENVIRONMENT=production
MONGO_URL=mongodb+srv://user:password@cluster.example.com/cfc
DB_NAME=cfc

# Prefer secret-manager injected JSON in production, or mount the file privately.
FIREBASE_SA_PATH={"type":"service_account","project_id":"your-firebase-project-id"}
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

UPLOAD_DIR=/var/app/uploads
PUBLIC_BASE_URL=https://api.carryfastcorp.com
CORS_ORIGINS=https://carryfastcorp.com,https://www.carryfastcorp.com

# Optional Google Analytics 4 admin dashboard metrics.
GA4_PROPERTY_ID=YOUR_GA4_PROPERTY_ID
GA4_SA_PATH={"type":"service_account","project_id":"your-firebase-project-id"}

ADMIN_SEED_EMAIL=admin@carryfastcorp.com
ADMIN_SEED_PASSWORD=replace-with-a-strong-unique-password
ADMIN_SEED_NAME=Admin
